# ── LLM Provider: AWS Bedrock (primary) ──
# Credentials via the boto3 default chain (AWS_PROFILE locally, instance role on EC2).
AWS_PROFILE=akarsh-deepprobe
BEDROCK_REGION=ap-south-1
# Agent = Qwen3-235B (DeepSeek dropped: DSML function-call leak + ReAct non-termination).
BEDROCK_AGENT_MODEL=qwen.qwen3-235b-a22b-2507-v1:0
BEDROCK_SQLGEN_MODEL=qwen.qwen3-32b-v1:0
BEDROCK_FALLBACK_MODEL=moonshotai.kimi-k2.5
# Agent temp = 0 for baseline<->candidate diffability (D9). MoE-on-Bedrock isn't
# bitwise-deterministic even at 0, but 0 minimizes sampling noise so a v1->v2 diff
# reflects real behavior change. Set >0 only if diffing distributions over N samples.
BEDROCK_FORCE_TEMPERATURE=0

# ── LLM Provider: OpenRouter (deprecated — Bedrock is primary) ──
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=deepseek/deepseek-v3.2
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web Search
TAVILY_API_KEY=your-tavily-key-here

# Database
DATABASE_URL=postgresql://user:password@hostname.neon.tech/dbname?sslmode=require

# Phase 6
TOKEN_COMPRESS_THRESHOLD=32000

# Phase 8
REDIS_URL=

# Phase 9
ENABLE_HARDENING=false
ENABLE_NEMO_GUARDRAILS=false
MAX_TOOL_CALLS_PER_SESSION=50

# Phase 10 — Observability
APP_LOG_LEVEL=INFO

# ── LangSmith ──
ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hr-recruitment-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Langfuse ──
ENABLE_LANGFUSE=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Local OTEL span mirror ──
ENABLE_LOCAL_OTEL=false
LOCAL_OTEL_DIR=traces/otel/

# ── Galileo AI ──
ENABLE_GALILEO=false
GALILEO_API_KEY=
GALILEO_PROJECT=hr-recruitment-agent
GALILEO_LOG_STREAM=default
GALILEO_CONSOLE_URL=
