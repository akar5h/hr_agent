{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockAndQuotaDiscoveryCP0",
      "Effect": "Allow",
      "Action": [
        "bedrock:ListFoundationModels",
        "bedrock:GetFoundationModel",
        "bedrock:ListInferenceProfiles",
        "bedrock:GetInferenceProfile",
        "servicequotas:GetServiceQuota",
        "servicequotas:ListServiceQuotas",
        "servicequotas:ListAWSDefaultServiceQuotas"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BedrockInvokeForLocalDevAndPreflight",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:*::foundation-model/*",
        "arn:aws:bedrock:*:854847082059:inference-profile/*",
        "arn:aws:bedrock:*:854847082059:application-inference-profile/*"
      ]
    },
    {
      "Sid": "RdsDiscoveryForVpcWiring",
      "Effect": "Allow",
      "Action": [
        "rds:DescribeDBInstances",
        "rds:DescribeDBClusters",
        "rds:DescribeDBSubnetGroups"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Ec2ReadForLaunch",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeInstanceTypes",
        "ec2:DescribeImages",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeVpcs",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DescribeIamInstanceProfileAssociations"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SsmRunCommandDocument",
      "Effect": "Allow",
      "Action": [ "ssm:SendCommand" ],
      "Resource": "arn:aws:ssm:ap-south-1::document/AWS-RunShellScript"
    },
    {
      "Sid": "SsmRunCommandOnProjectInstances",
      "Effect": "Allow",
      "Action": [ "ssm:SendCommand" ],
      "Resource": "arn:aws:ec2:ap-south-1:854847082059:instance/*",
      "Condition": { "StringEquals": { "aws:ResourceTag/project": "hr-traffic-v0" } }
    },
    {
      "Sid": "SsmCommandResults",
      "Effect": "Allow",
      "Action": [ "ssm:GetCommandInvocation", "ssm:ListCommands", "ssm:ListCommandInvocations" ],
      "Resource": "*"
    },
    {
      "Sid": "Ec2LaunchInRegion",
      "Effect": "Allow",
      "Action": [ "ec2:RunInstances" ],
      "Resource": "*",
      "Condition": { "StringEquals": { "aws:RequestedRegion": "ap-south-1" } }
    },
    {
      "Sid": "Ec2TagOnCreate",
      "Effect": "Allow",
      "Action": [ "ec2:CreateTags" ],
      "Resource": "*",
      "Condition": { "StringEquals": { "ec2:CreateAction": "RunInstances" } }
    },
    {
      "Sid": "Ec2LifecycleOnlyProjectTagged",
      "Effect": "Allow",
      "Action": [ "ec2:StartInstances", "ec2:StopInstances", "ec2:TerminateInstances" ],
      "Resource": "*",
      "Condition": { "StringEquals": { "aws:ResourceTag/project": "hr-traffic-v0" } }
    },
    {
      "Sid": "SecurityGroupForEc2ToRds",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:DeleteSecurityGroup"
      ],
      "Resource": "*",
      "Condition": { "StringEquals": { "aws:RequestedRegion": "ap-south-1" } }
    },
    {
      "Sid": "PassInstanceRoleToEc2Only",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::854847082059:role/hr-traffic-bedrock-ec2-role",
      "Condition": { "StringEquals": { "iam:PassedToService": "ec2.amazonaws.com" } }
    },
    {
      "Sid": "ManageInstanceRolePinnedName",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:TagRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies"
      ],
      "Resource": "arn:aws:iam::854847082059:role/hr-traffic-bedrock-ec2-role"
    },
    {
      "Sid": "ManageInstanceProfilePinnedName",
      "Effect": "Allow",
      "Action": [
        "iam:CreateInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:GetInstanceProfile"
      ],
      "Resource": "arn:aws:iam::854847082059:instance-profile/hr-traffic-bedrock-ec2-role"
    },
    {
      "Sid": "ReadIamForVerify",
      "Effect": "Allow",
      "Action": [ "iam:GetRole", "iam:GetInstanceProfile", "iam:ListInstanceProfilesForRole" ],
      "Resource": "*"
    },
    {
      "Sid": "S3StageCodeReadArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutLifecycleConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::hr-traffic-v0-854847082059",
        "arn:aws:s3:::hr-traffic-v0-854847082059/*"
      ]
    },
    {
      "Sid": "SsmStageSecrets",
      "Effect": "Allow",
      "Action": [ "ssm:PutParameter", "ssm:GetParameter", "ssm:DeleteParameter" ],
      "Resource": "arn:aws:ssm:ap-south-1:854847082059:parameter/hr-traffic-v0/*"
    },
    {
      "Sid": "SsmSessionManagerConnect",
      "Effect": "Allow",
      "Action": [ "ssm:StartSession", "ssm:TerminateSession", "ssm:DescribeSessions", "ssm:DescribeInstanceInformation" ],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogsWatch",
      "Effect": "Allow",
      "Action": [
        "logs:GetLogEvents",
        "logs:FilterLogEvents",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:ap-south-1:854847082059:log-group:/hr-traffic-v0/*"
    }
  ]
}
